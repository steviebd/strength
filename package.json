{
  "name": "strength",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --cwd apps/expo start",
    "dev:worker": "lsof -ti:8787 | xargs kill -9 2>/dev/null; bun --cwd apps/worker dev --port 8787",
    "build:worker": "bun --cwd apps/worker build",
    "db:generate": "bun --cwd packages/db generate",
    "db:migrate": "bun --cwd packages/db migrate",
    "db:push": "bun --cwd packages/db push",
    "setup": "bun install"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
