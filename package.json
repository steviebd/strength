{
  "name": "strength",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:expo": "infisical run --env=dev -- bun --filter @strength/expo dev",
    "dev:worker": "infisical run --env=dev -- bun run --filter @strength/worker dev",
    "db:generate": "bun --filter @strength/db db:generate",
    "db:push:dev": "cd apps/worker && wrangler d1 migrations apply strength-db --local",
    "db:reset": "rm -rf apps/worker/.wrangler/ && bun run db:push:dev",
    "lint:keys": "bun scripts/lint-react-keys.mjs",
    "typecheck": "bun --filter '*' typecheck",
    "setup": "bun install",
    "check": "source ~/.vite-plus/env && vp check && bun run typecheck",
    "test": "source ~/.vite-plus/env && vp test run",
    "lint": "source ~/.vite-plus/env && vp lint && bun run lint:keys",
    "fmt": "source ~/.vite-plus/env && vp fmt"
  },
  "dependencies": {
    "expo": "~55.0.16",
    "expo-constants": "~55.0.15",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "react-native": "0.83.6",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vite-plus": "^0.1.18",
    "wrangler": "^4.84.0"
  },
  "packageManager": "bun@1.2.9"
}
