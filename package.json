{
  "name": "strength",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n worker,expo -c blue,cyan \"bun run --filter @strength/worker dev\" \"bun run --filter @strength/expo dev\"",
    "dev:remote": "bun run --filter @strength/worker dev:remote",
    "dev:expo": "cd apps/expo && bun run dev",
    "dev:expo:staging": "infisical run --env=staging -- bun --filter @strength/expo dev",
    "build:android:staging": "cd apps/expo && bun run build:android:staging",
    "e2e:maestro": "maestro test apps/expo/.maestro",
    "e2e:maestro:auth": "maestro test apps/expo/.maestro/00-auth.yml",
    "e2e:maestro:workouts": "maestro test apps/expo/.maestro/10-workouts.yml",
    "e2e:maestro:programs": "maestro test apps/expo/.maestro/20-programs.yml",
    "e2e:maestro:nutrition": "maestro test apps/expo/.maestro/30-nutrition.yml",
    "serve:builds": "cd apps/expo/builds && ifconfig en0 | grep 'inet ' | awk '{print $2}' && python3 -m http.server 8080",
    "db:generate": "bun --filter @strength/db db:generate",
    "db:apply:local": "bun run --filter @strength/worker db:apply:local",
    "db:apply:remote": "bun run --filter @strength/worker db:apply:remote",
    "db:apply:staging": "bun run --filter @strength/worker db:apply:staging",
    "db:apply:prod": "bun run --filter @strength/worker db:apply:prod",
    "db:reset": "rm -rf apps/worker/.wrangler/ && bun run db:apply:local",
    "lint:keys": "bun scripts/lint-react-keys.mjs",
    "typecheck": "bun --filter '*' typecheck",
    "setup": "bun install",
    "check": "export PATH=\"$HOME/.vite-plus/bin:$PATH\" && vp check && bun run lint:keys && bun run typecheck",
    "test": "export PATH=\"$HOME/.vite-plus/bin:$PATH\" && vp test run",
    "lint": "source ~/.vite-plus/env && vp lint && bun run lint:keys",
    "fmt": "source ~/.vite-plus/env && vp fmt"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.8",
    "@cloudflare/workers-types": "4.20260424.1",
    "@react-native-community/datetimepicker": "8.6.0",
    "@strength/db": "workspace:*",
    "@strength/worker": "workspace:*",
    "@tanstack/react-query": "5.100.1",
    "better-auth": "^1.6.8",
    "drizzle-orm": "^0.45.2",
    "expo": "~55.0.18",
    "expo-constants": "~55.0.15",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "hono": "^4.12.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "0.7.4",
    "vitest": "^4.1.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "patch-package": "^8.0.1",
    "typescript": "5.9.3",
    "vite-plus": "^0.1.19",
    "wrangler": "^4.84.1"
  },
  "packageManager": "bun@1.3.13"
}
