# Cloudflare D1 Database
# Create with: cd apps/worker && wrangler d1 create strength-db
# Then update wrangler.toml with the database_id

# Better Auth (generate secret with: npx -y @better-auth/cli secret)
BETTER_AUTH_SECRET=your-secret-here

# Google OAuth (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Worker API URL (for local development: http://localhost:8787)
EXPO_PUBLIC_API_URL=http://localhost:8787
