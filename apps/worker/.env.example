# ----------------------------------------------------------
# Strength Worker Environment Configuration
# ----------------------------------------------------------
# LOCAL DEV ONLY - staging/prod secrets are managed via Infisical
# This file serves as a reference for all environment variables
# and their expected values per environment (dev/staging/prod)

# ----------------------------------------------------------
# Core
# ----------------------------------------------------------

# Environment mode
# Values: development (verbose auth logs) | staging | production
# - dev: development
# - staging: staging
# - prod: production
APP_ENV=development

# Remote D1 database ID (set at runtime from Infisical)
# - dev: remote dev D1 UUID for `bun run dev:remote`
# - staging: staging D1 UUID
# - prod: production D1 UUID
CLOUDFLARE_D1_ID=

# ----------------------------------------------------------
# Auth (Better Auth)
# ----------------------------------------------------------

# Secret key for signing auth tokens (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Base URL for this worker
# - dev: http://localhost:8787
# - staging: https://worker-staging.yourdomain.com
# - prod: https://worker.yourdomain.com
BETTER_AUTH_URL=http://localhost:8787

# Trusted OAuth redirect origins (comma-separated)
BETTER_AUTH_TRUSTED_ORIGINS=strength://,strength://*,http://localhost:*,http://127.0.0.1:*,exp://*,exp://127.0.0.1:8081/**

# Expo client API URL (update after first deploy)
# - dev: http://localhost:8787
# - staging: https://worker-staging.yourdomain.com
# - prod: https://worker.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:8787

# ----------------------------------------------------------
# WHOOP Integration
# ----------------------------------------------------------
# Register your app at https://developer.whoop.com
# Set the OAuth Redirect URI in the WHOOP developer dashboard to:
#   ${BETTER_AUTH_URL}/api/auth/whoop/callback

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_WEBHOOK_SECRET=
WHOOP_SYNC_RATE_LIMIT_PER_HOUR=10

# ----------------------------------------------------------
# Encryption
# ----------------------------------------------------------

# Master key for secure token storage
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
ENCRYPTION_MASTER_KEY=

# ----------------------------------------------------------
# Cloudflare AI Gateway
# ----------------------------------------------------------

# AI Gateway instance name
# - dev: workout-ai-dev
# - staging: workout-ai-staging
# - prod: workout-ai-prod
AI_GATEWAY_NAME=workout-ai-dev

# AI model to use
AI_MODEL_NAME=workers-ai/@cf/moonshotai/kimi-k2.5

CF_AI_GATEWAY_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
INFISICAL_PROJECT_ID=
