# ----------------------------------------------------------
# Strength Worker Environment Configuration
# ----------------------------------------------------------
# LOCAL DEV ONLY - staging/prod secrets are managed via Infisical
# This file serves as a reference for all environment variables
# and their expected values per environment (dev/staging/prod)

# ----------------------------------------------------------
# Core
# ----------------------------------------------------------

# Environment mode
# Values: development (verbose auth logs) | staging | production
# - dev: development
# - staging: staging
# - prod: production
APP_ENV=development

# Deep link scheme for the mobile app (used for OAuth redirect URIs)
# Must match the scheme in Expo app.json and EXPO_PUBLIC_APP_SCHEME in expo .env
# Change this if you rebrand the app to avoid breaking deep links and OAuth
APP_SCHEME=strength

# Remote D1 database ID (set at runtime from Infisical)
# - dev: remote dev D1 UUID for `bun run dev:remote`
# - staging: staging D1 UUID
# - prod: production D1 UUID
CLOUDFLARE_D1_ID=

# ----------------------------------------------------------
# Auth (Better Auth)
# ----------------------------------------------------------

# Secret key for signing auth tokens (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Base URL for this worker (server-side auth/callback config)
# - dev on iOS simulator/same machine: http://localhost:8787
# - dev on Expo Go physical device with WHOOP OAuth:
#   https://strength-dev.your-domain.com
# - staging: https://strength-worker-staging.stevio-wonder-cloudflare.workers.dev
# - prod: https://worker.yourdomain.com
#
# WHOOP only allows http redirect_uri values for localhost-style hosts.
# Use HTTPS for physical-device OAuth testing. A Cloudflare Tunnel hostname is
# the recommended local-dev value because it gives WHOOP and Expo Go a stable
# HTTPS URL that forwards to wrangler on this MacBook.
WORKER_BASE_URL=http://localhost:8787

# Port where Metro dev server is running (Expo web with HMR)
# When set, worker proxies non-API routes to Metro at localhost:EXPO_METRO_PORT
# This enables HMR at the tunnel URL (strength-dev.stevenduong.com)
EXPO_METRO_PORT=8081

# Public Worker base URL embedded into Expo builds
# - iOS simulator/same machine can use http://localhost:8787
# - physical Android/iOS device should use the HTTPS tunnel hostname
# Uses Infisical secret reference: ${WORKER_BASE_URL}
EXPO_PUBLIC_WORKER_BASE_URL=${WORKER_BASE_URL}

# Trusted origins for Better Auth (comma-separated)
# Uses Infisical secret reference: ${WORKER_BASE_URL},exp://*,${APP_SCHEME}://
BETTER_AUTH_TRUSTED_ORIGINS=${WORKER_BASE_URL},exp://*,${APP_SCHEME}://

# ----------------------------------------------------------
# Cloudflare Tunnel for local Expo Go + WHOOP OAuth
# ----------------------------------------------------------
# Optional. Set both values in Infisical dev to make `bun run dev` and
# `bun run dev:remote` auto-start a named Cloudflare Tunnel on this MacBook.
#
# The tunnel maps:
#   https://${CLOUDFLARE_TUNNEL_HOSTNAME} -> http://localhost:8787
#
# Use this when testing from Expo Go on a physical device because:
# - the device cannot reach MacBook localhost
# - WHOOP rejects insecure http redirect_uri values except localhost hosts
# - the OAuth callback must be reachable by WHOOP's public servers
#
# One-time local setup:
#   brew install cloudflared
#   cloudflared tunnel login
#   cloudflared tunnel create strength-dev
#   cloudflared tunnel route dns strength-dev strength-dev.your-domain.com
#
# `bun run dev` starts:
#   cloudflared tunnel run --url http://localhost:8787 strength-dev
#
# That means a local ~/.cloudflared/config.yml is not required for this repo.
# If you manage ingress in the Cloudflare dashboard or a config file instead,
# keep it equivalent to:
#   strength-dev.your-domain.com -> http://localhost:8787
#
# WHOOP Developer Portal redirect URI:
#   https://strength-dev.your-domain.com/api/auth/whoop/callback
#
# Privacy/security note:
# This must be a public hostname, not a Cloudflare private hostname or private
# CIDR route, because WHOOP's OAuth service has to call the redirect URI. Keep
# it in dev only, use an unguessable/dev-only subdomain if desired, and stop
# `bun run dev` when not testing. The worker still enforces app auth on protected
# APIs; the OAuth callback itself must remain publicly reachable.
CLOUDFLARE_TUNNEL_NAME=
CLOUDFLARE_TUNNEL_HOSTNAME=

# ----------------------------------------------------------
# WHOOP Integration
# ----------------------------------------------------------
# Register your app at https://developer.whoop.com
# Set the OAuth Redirect URI in the WHOOP developer dashboard to:
#   ${WORKER_BASE_URL}/api/auth/whoop/callback
#
# Local examples:
# - iOS simulator/same machine:
#   http://localhost:8787/api/auth/whoop/callback
# - Expo Go physical device:
#   https://strength-dev.your-domain.com/api/auth/whoop/callback

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_WEBHOOK_SECRET=
WHOOP_SYNC_RATE_LIMIT_PER_HOUR=10

# ----------------------------------------------------------
# Encryption
# ----------------------------------------------------------

# Master key for secure token storage
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
ENCRYPTION_MASTER_KEY=

# ----------------------------------------------------------
# Cloudflare AI Gateway
# ----------------------------------------------------------

# AI Gateway instance name
# - dev: workout-ai-dev
# - staging: workout-ai-staging
# - prod: workout-ai-prod
AI_GATEWAY_NAME=workout-ai-dev

# AI model to use
AI_MODEL_NAME=workers-ai/@cf/moonshotai/kimi-k2.5

CF_AI_GATEWAY_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
INFISICAL_PROJECT_ID=
