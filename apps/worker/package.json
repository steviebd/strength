{
  "name": "@strength/worker",
  "private": true,
  "scripts": {
    "dev": "infisical export --env=dev --silent --format=dotenv --output-file=.dev.vars && bun run scripts/setup-dev.ts && bun run dev:wrangler",
    "dev:wrangler": "wrangler dev --ip 0.0.0.0",
    "deploy": "wrangler deploy",
    "db:apply:local": "wrangler d1 migrations apply strength-db --local",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.5",
    "@strength/db": "workspace:*",
    "ai-gateway-provider": "^3.1.3",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@types/node": "^25.6.0"
  }
}
