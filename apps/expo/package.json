{
  "name": "@strength/expo",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "sync-env:dev": "bun run scripts/sync-expo-env.ts dev",
    "sync-env:staging": "bun run scripts/sync-expo-env.ts staging",
    "dev": "bun run sync-env:dev && bun run dev:metro",
    "dev:metro": "lsof -ti:8081 | xargs kill -9 2>/dev/null || true; EXPO_NO_METRO_LAZY=1 expo start --clear -- --port 8081",
    "android": "EXPO_NO_METRO_LAZY=1 expo start --android",
    "ios": "EXPO_NO_METRO_LAZY=1 expo start --ios",
    "web": "EXPO_NO_METRO_LAZY=1 expo start --web",
    "build:web": "npx tsx scripts/web-build.ts",
    "logs:android": "adb logcat -c && adb logcat '*:S' 'ReactNative:V' 'ReactNativeJS:V' 'AndroidRuntime:E' 'ExpoModulesCore:E'",
    "typecheck": "bunx tsc --noEmit",
    "build:android:staging": "bun run scripts/build-android-staging.ts"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.8",
    "@better-auth/infra": "^0.2.5",
    "@expo/vector-icons": "^15.0.0",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/native": "^7.0.0",
    "@strength/db": "*",
    "@tanstack/react-query": "5.100.1",
    "better-auth": "^1.6.8",
    "expo": "~55.0.18",
    "expo-constants": "~55.0.15",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-network": "~55.0.8",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.10"
  }
}
