{
  "name": "@strength/expo",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "sync-env:dev": "bun run scripts/sync-expo-env.ts dev",
    "sync-env:staging": "bun run scripts/sync-expo-env.ts staging",
    "sync-env:prod": "bun run scripts/sync-expo-env.ts prod",
    "dev": "bun run sync-env:dev && bun run dev:metro",
    "dev:metro": "lsof -ti:8081 | xargs kill -9 2>/dev/null || true; EXPO_NO_METRO_LAZY=1 expo start --clear -- --port 8081",
    "android": "EXPO_NO_METRO_LAZY=1 expo start --android",
    "ios": "EXPO_NO_METRO_LAZY=1 expo start --ios",
    "web": "EXPO_NO_METRO_LAZY=1 expo start --web",
    "build:web": "npx tsx scripts/web-build.ts",
    "logs:android": "adb logcat -c && adb logcat -b main -b system -b crash -v time AndroidRuntime:E ReactNative:V ReactNativeJS:V ExpoModulesCore:V DEBUG:E libc:E System.err:W '*:S'",
    "logs:android:crash": "bun run scripts/capture-android-crash.ts",
    "typecheck": "bunx tsc --noEmit",
    "size:android": "bun run scripts/android-size-report.ts",
    "build:android:staging": "bun run scripts/build-android-staging.ts",
    "build:android:prod": "bun run scripts/build-android-prod.ts"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.9",
    "@better-auth/infra": "^0.2.5",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-navigation/native": "^7.2.2",
    "@strength/db": "*",
    "@tanstack/react-query": "5.100.7",
    "better-auth": "^1.6.9",
    "expo": "~55.0.19",
    "expo-constants": "~55.0.15",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-network": "~55.0.8",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sqlite": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.83.9",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14"
  }
}
