{
  "name": "@strength/expo",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --clear",
    "dev:staging": "infisical run --env=staging -- bun run dev",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:build": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "build:android:staging": "bun run scripts/build-android-staging.ts"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.5",
    "@expo/vector-icons": "^15.0.0",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/native": "^7.0.0",
    "@strength/db": "*",
    "@tanstack/react-query": "^5.99.2",
    "better-auth": "^1.6.5",
    "expo": "~55.0.17",
    "expo-constants": "~55.0.15",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-network": "~55.0.8",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10"
  }
