{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "staging": {
      "android": {
        "buildType": "apk"
      }
    },
    "e2e-test": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APP_SCHEME": "strength"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "enableProguardInReleaseBuilds": true
      }
    },
    "production-apk": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "enableProguardInReleaseBuilds": true
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      }
    }
  }
}
